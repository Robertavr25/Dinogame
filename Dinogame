import pygame
import random

pygame.init()
WIDTH, HEIGHT = 1200, 600
GROUND_HEIGHT = HEIGHT - 100
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
GRAY = (200, 200, 200)

screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Dino Game - Chrome Style")
clock = pygame.time.Clock()
font = pygame.font.SysFont("Arial", 24)

class Dinosaur:
    def __init__(self):
        self.x = 50
        self.y = GROUND_HEIGHT - 60
        self.width = 44
        self.height = 60
        self.y_velocity = 0
        self.gravity = 2500  # Pixeli pe secundă pătrat
        self.jump_power = -800
        self.is_grounded = True
        self.is_ducking = False

    def jump(self):
        if self.is_grounded:
            self.y_velocity = self.jump_power
            self.is_grounded = False

    def duck(self, ducking):
        self.is_ducking = ducking
        if ducking:
            self.height = 30  # Se apleacă
        else:
            self.height = 60  # Revine la normal

    def update(self, dt):
        # Aplicăm gravitația
        self.y_velocity += self.gravity * dt
        self.y += self.y_velocity * dt

        if self.y >= GROUND_HEIGHT - self.height:
            self.y = GROUND_HEIGHT - self.height
            self.y_velocity = 0
            self.is_grounded = True

    def draw(self, surface):
        color = (100, 100, 100) if self.is_ducking else BLACK
        rect = pygame.Rect(self.x, self.y, self.width, self.height)
        pygame.draw.rect(surface, color, rect)

    def get_rect(self):
        return pygame.Rect(self.x, self.y, self.width, self.height)

class Obstacle:
    def __init__(self, x, velocity):
        self.x = x
        self.velocity = velocity
        self.type = random.choice(["cactus", "bird"])
        self.width = 30 if self.type == "cactus" else 40
        self.height = 50 if self.type == "cactus" else 30
        
        if self.type == "cactus":
            self.y = GROUND_HEIGHT - self.height
        else:
          
            self.y = GROUND_HEIGHT - 70 # Pasăre joasă (necesită săritură sau aplecare)

    def update(self, dt):
        self.x -= self.velocity * dt

    def draw(self, surface):
        color = (200, 0, 0) if self.type == "cactus" else (0, 0, 255)
        pygame.draw.rect(surface, color, (self.x, self.y, self.width, self.height))

    def get_rect(self):
        return pygame.Rect(self.x, self.y, self.width, self.height)

def init_game():
    return Dinosaur(), [], 0, 500  # dino, obstacles, score, current_velocity

def main():
    dino, obstacles, score, velocity = init_game()
    high_score = 0
    game_over = False
    last_frame_time = pygame.time.get_ticks()

    running = True
    while running:
        # Calculăm Delta Time
        t = pygame.time.get_ticks()
        dt = (t - last_frame_time) / 1000.0
        last_frame_time = t

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE or event.key == pygame.K_UP:
                    if game_over: # Restart
                        dino, obstacles, score, velocity = init_game()
                        game_over = False
                    else:
                        dino.jump()
                if event.key == pygame.K_DOWN:
                    dino.duck(True)
            
            if event.type == pygame.KEYUP:
                if event.key == pygame.K_DOWN:
                    dino.duck(False)

        if not game_over:
            dino.update(dt)
            if len(obstacles) == 0 or obstacles[-1].x < WIDTH - random.randint(300, 600):
                obstacles.append(Obstacle(WIDTH, velocity))

            for obs in obstacles[:]:
                obs.update(dt)
                if obs.x < -50:
                    obstacles.remove(obs)
                if dino.get_rect().colliderect(obs.get_rect()):
                    game_over = True
                    if score > high_score:
                        high_score = score

            score += dt * 10
            velocity += dt * 2 # Jocul devine mai rapid treptat

        screen.fill(WHITE)
        
        pygame.draw.line(screen, BLACK, (0, GROUND_HEIGHT), (WIDTH, GROUND_HEIGHT), 2)
        
        dino.draw(screen)
        for obs in obstacles:
            obs.draw(screen)

        score_txt = font.render(f"Score: {int(score)}  High Score: {int(high_score)}", True, BLACK)
        screen.blit(score_txt, (20, 20))

        if game_over:
            over_txt = font.render("GAME OVER - Press SPACE to Restart", True, (200, 0, 0))
            screen.blit(over_txt, (WIDTH//2 - 150, HEIGHT//2))

        pygame.display.flip()
        clock.tick(60)

    pygame.quit()

if __name__ == "__main__":
    main()
